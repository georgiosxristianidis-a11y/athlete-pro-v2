# Athlete Pro - server env. Copy to .env and fill in.

# -- AI Coach (at least one key needed for AI features; app works without) --
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash
COACH_STREAM_TIMEOUT_MS=120000
COACH_SSE_HEARTBEAT_MS=15000

# -- Supabase cloud sync (optional -- offline-first works without it) --
SUPABASE_URL=
SUPABASE_ANON_KEY=

# -- Firebase (optional, only if used by an integration) --
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=

# -- Server --
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# CSV of allowed origins for CORS; defaults to localhost:3000/3001 if unset
ALLOWED_ORIGINS=
