{
  "name": "athlete-pro",
  "version": "1.25.2",
  "type": "module",
  "description": "PPL Workout Tracker with AI Coach",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:lan": "node server.js --lan",
    "lint": "eslint . && stylelint \"css/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test \"test/*.test.js\"",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:all": "node --test \"test/*.test.js\" && playwright test --config=playwright.config.js",
    "lhci": "node scripts/lighthouse.js",
    "security:audit": "npm audit --audit-level=high",
    "security:sast": "npm run lint",
    "security:check": "npm run security:audit && npm run security:sast",
    "postinstall": "git config core.hooksPath .githooks",
    "build:sw": "node scripts/build-sw.mjs",
    "build": "npm run build:sw"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.102.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.14.0"
  }
}
