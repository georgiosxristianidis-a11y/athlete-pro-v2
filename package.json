{
  "name": "athlete-pro",
  "version": "1.15.4",
  "type": "module",
  "description": "PPL Workout Tracker with AI Coach (Frozen — see FIT ELITE for active dev)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:all": "node --test && playwright test --config=playwright.config.js",
    "lhci": "node scripts/lighthouse.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@google/genai": "^1.50.1",
    "@supabase/supabase-js": "^2.102.1",
    "compression": "^1.8.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1"
  }
}
