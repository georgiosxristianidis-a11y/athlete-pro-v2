{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MAX_THINKING_TOKENS": "16000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_COST_WARNINGS": "0",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "300000"
  },
  "permissions": {
    "allow": [
      "Read(**/.env.example)",
      "Bash(npm run *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(vercel *)",
      "Bash(ls *)",
      "Bash(cat *.js)",
      "Bash(cat *.css)",
      "Bash(cat *.html)",
      "Bash(cat *.json)",
      "Bash(cat *.md)",
      "Read(//c/PROJECTS/FIT-ELITE/**)",
      "Bash(gh repo:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(xxd -l 16 \"c:\\\\PROJECTS\\\\athlete-pro\\\\js\\\\workout.store.js\")",
      "Bash(curl -s http://localhost:3000/js/workout.store.js)",
      "Bash(curl -s http://localhost:3000/js/workout.view.js)",
      "Bash(curl -s http://localhost:3000/js/app.js)",
      "Bash(curl -sI http://localhost:3000/js/app.js)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/)",
      "Bash(xargs kill:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *secret*)",
      "Bash(curl *api_key*)",
      "Bash(cat *.env*)"
    ]
  },
  "model": "claude-opus-4.6"
}
